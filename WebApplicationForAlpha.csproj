<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>

	  <!-- SPA Configuration -->
	  <SpaRoot>ClientApp\</SpaRoot>
	  <SpaProxyServerUrl>http://localhost:4200</SpaProxyServerUrl>
	  <SpaProxyTimeoutInSeconds>120</SpaProxyTimeoutInSeconds>
	  <SpaProxyLaunchCommand>npm start</SpaProxyLaunchCommand>
	  
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.OpenApi" Version="8.0.23" />
    <PackageReference Include="Swashbuckle.AspNetCore" Version="6.6.2" />
	<PackageReference Include="Microsoft.AspNetCore.SpaProxy" Version="8.0.23" />
  </ItemGroup>

  <ItemGroup>
    <Folder Include="ClientApp\src\app\services\" />
  </ItemGroup>

</Project>
